root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,txt}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.mk]
indent_style = tab

[*.{sh,bash}]
indent_style = space
indent_size = 2

[*.{c,h,java,kt,kts,gradle,properties}]
indent_style = tab
indent_size = 4

[*.{xml,yml,yaml,json}]
indent_style = space
indent_size = 2
